# Copie para .env. Nunca commite o .env.

# Entrada geral (Brasil)
TIKTOK_START_URL=https://shop.tiktok.com/br

# Hub “diretório de categorias” — equivalente ao 1º link que você mandou (breadcrumb / SEO).
# Versão curta costuma bastar; ou cole a URL completa com ?source=…
TIKTOK_CATEGORY_HUB_URL=https://shop.tiktok.com/br/c

# Vitrines fixas (opcional). Para usar SÓ as categorias do hub: deixe a linha abaixo vazia.
TIKTOK_CATEGORY_URLS=

# Hub: descobre todas as vitrines /br/c/slug/ID (scroll no DOM). Isto + linha acima vazia = “todas as categorias”.
TIKTOK_SITEMAP_URL=https://shop.tiktok.com/br/c
# Opcional: mais scroll no hub se faltar categoria — TIKTOK_HUB_SCROLL_ROUNDS=28

# Taxonomia só do Sitemap (npm run taxonomy → output/categories.json). Não coleta produtos.
# Grava só categorias MASTER (tipografia bold / títulos), não a lista inteira de subcategorias.
# Usa TAXONOMY_SITEMAP_URL se definido; senão TIKTOK_SITEMAP_URL; senão o hub BR.
# TAXONOMY_OUTPUT_JSON=./output/categories.json
# TAXONOMY_SITEMAP_URL=https://shop.tiktok.com/br/c

# Snapshots do dashboard por categoria master (ficheiro à parte; não mexe em produtos.json).
# npm run master-snapshots
# MASTER_SNAPSHOT_CATEGORIES_JSON=./output/categories.json
# MASTER_SNAPSHOT_OUTPUT_JSON=./output/master_category_snapshots.json
# MASTER_SNAPSHOT_CATEGORY_DELAY_MS=4500
# MASTER_SNAPSHOT_POST_LOAD_MS=1800
# MASTER_SNAPSHOT_MAX_MASTERS=3

# Se preferir resolver pelo texto no hub em vez de URL fixa:
# TIKTOK_CATEGORY_NAMES=Womenswear & Underwear

TIKTOK_API_URL_INCLUDES=api/v,api/oec,oec,product,search,feed,shop,promotion,component,recommend

# Saída canónica JSON (sempre). CSV legado desligado por defeito.
OUTPUT_JSON=./output/produtos.json
# ENABLE_CSV=true
# OUTPUT_CSV=./output/produtos.csv
HEADLESS=false
USER_DATA_DIR=./chrome-profile

# Modo conservador (menos puzzle/captcha): um único switch. Delays/scroll/view-more mais baixos e teto de PDP/tempo
# quando as variáveis abaixo NÃO estão definidas. Se definires ex. PDP_DELAY_MIN_MS no .env, esse valor ganha.
# SAFE_SCRAPING=true
#
# Defaults aplicados só com SAFE_SCRAPING=true e env omitido:
#   RUN_DURATION_MINUTES     → 30 min  |  STOP_AFTER_PDP_OK  → 20
#   PDP_DELAY_*              → 8000–18000 ms  |  CATEGORY_DELAY_*  → 22000–60000 ms
#   LIST_SCROLL_MAX_ROUNDS   → 12  |  LIST_SCROLL_IDLE_LIMIT → 3
#   VIEW_MORE_MAX_CLICKS     → 40  |  CATEGORY_STAGNANT_PASSES → 2
# Sem limite de tempo com safe: RUN_DURATION_MINUTES=0

# Diagnóstico (puzzle/captcha): ritmo ainda mais baixo + logs [diag] no console + objeto `diagnostic` em metrics.json.
# Se ULTRA_SAFE_DIAGNOSTIC=true e não definires as variáveis abaixo, os defaults deste modo ganham sobre SAFE_SCRAPING.
# ULTRA_SAFE_DIAGNOSTIC=true
#
# Defaults só com env omitido: RUN_DURATION 8 min · STOP_AFTER_PDP_OK 5 · PDP_DELAY 12–25 s · CATEGORY_DELAY 30–90 s
# · LIST_SCROLL_MAX_ROUNDS 6 · VIEW_MORE_MAX_CLICKS 8 · CATEGORY_STAGNANT_PASSES 1

# CAPTCHA: o scraper NÃO resolve o puzzle sozinho. Com CAPTCHA_WAIT=true (default), ele PAUSA até tu
# resolveres no browser, depois continua. Desligar: CAPTCHA_WAIT=false (vai falhar/atropelar o modal).
# CAPTCHA_WAIT=true
# CAPTCHA_MAX_WAIT_MS=1800000
MANUAL_LOGIN_WAIT_MS=180000
# Verificação periódica da página/sessão (continua cedo quando o login termina)
MANUAL_LOGIN_POLL_MS=1500

CATEGORY_DELAY_MIN_MS=8000
CATEGORY_DELAY_MAX_MS=25000
VIEW_MORE_MAX_CLICKS=200
CATEGORY_STAGNANT_PASSES=3
LIST_SCROLL_MAX_ROUNDS=28
LIST_SCROLL_IDLE_LIMIT=4
PDP_DELAY_MIN_MS=2000
PDP_DELAY_MAX_MS=6000

# Amostra de reviews no produtos.json (texto + URLs de fotos + sku_id). Reduza para limitar tamanho do JSON.
# REVIEW_SAMPLE_MAX=5
# REVIEW_SAMPLE_MAX_TEXT=320
# REVIEW_SAMPLE_MAX_PHOTOS=2
# REVIEW_SAMPLE_MAX=0 desliga a gravação de reviews.

# Vídeo + propriedades + lista de SKUs na PDP (router). Reduza PDP_SKU_OFFERS_MAX se o JSON ficar grande.
# PDP_SKU_OFFERS_MAX=120
# PDP_PROPERTY_MAX=24
# PDP_PROPERTY_VALUES_MAX=80

# O 3º link que você mandou é PDP de exemplo (produto 1734607014972131260); o scraper monta essas URLs sozinho a partir da listagem.

# Tempo máximo da corrida em minutos. Omitir ou 0 = SEM LIMITE (até acabar a fila ou Ctrl+C).
# Teste rápido: RUN_DURATION_MINUTES=30
# RUN_DURATION_MINUTES=0

# Modo teste: parar após N produtos válidos em produtos.json (omitir = sem limite)
# MAX_PRODUCTS=5

# Parada controlada: após N PDPs bem-sucedidos no run (metrics.pdp_ok), gravar e encerrar normalmente (omitir = sem limite)
# STOP_AFTER_PDP_OK=20

# Observabilidade (default: métricas agregadas em output/metrics.json; logs extra desligados)
# Log JSON por produto na extração de preço (productExtract.pickPrecoAtual): product_id, extracted_prices, chosen_price, chosen_source
# DEBUG_PRICE_EXTRACTION=true
# Por produto normalizado na rede: chosen_id, field_used, has_product_id_anywhere (objeto raw completo)
# DEBUG_NETWORK_PICK_ID=true
# DEBUG_SCRAPER=true
# METRICS_JSON_PATH=./output/metrics.json
# DISCARDED_DEBUG_PATH=./output/discarded_debug.json

# PostgreSQL: raw_events (telemetria) + opcionalmente tabela `products` (catálogo analítico).
# Migrações: db/migrations/001_raw_events.sql e db/migrations/002_products.sql
# Com DATABASE_URL e PRODUCTS_DB_SYNC=true, após cada flush sobe colunas quentes + JSONB `payload`.
# PRODUCTS_DB_SYNC=true

# PostgreSQL (Fase 1+: db/migrations/001_raw_events.sql; telemetria raw_events)
# DATABASE_URL=postgres://user:pass@localhost:5432/tiktok_scraper
# PG_SSL=false
# PG_POOL_MAX=10
# Amostragem de body_json em raw_events; erros e endpoints forçados gravam sempre inline
# RAW_EVENT_SAMPLE_RATE=0.005
# Buffer raw_events (Fase 1.1: sem await no sniffer; flush em lote)
# RAW_EVENT_BUFFER_MAX=5000
# RAW_EVENT_FLUSH_MS=2000
# RAW_EVENT_BATCH_SIZE=100
# Logs de cada flush: silent desliga; RAW_EVENT_LOG_FLUSH_EVERY=N regista 1 de cada N lotes (omitir = 1)
# RAW_EVENT_LOG_FLUSH=silent
# RAW_EVENT_LOG_FLUSH_EVERY=10
# Endpoint keys exactas (METHOD + host + path, como buildEndpointKey) para body_json inline
# RAW_EVENT_FORCE_INLINE_ENDPOINT_KEYS=GET shop.tiktok.com /api/exemplo
