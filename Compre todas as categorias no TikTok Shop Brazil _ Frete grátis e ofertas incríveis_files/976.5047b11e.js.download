wnload_app_selling_point_title4:"Aba Loja",tts_shop_download_download_button2:"Baixar aplicativo",tts_shop_download_selling_point_desc1:"Conte\xfado selecionado por uma comunidade que personaliza a experi\xeancia de compra",tts_shop_download_selling_point_desc2:"Tudo o que suas marcas e criadores favoritos est\xe3o curtindo agora, com transmiss\xf5es ao vivo divertidas",tts_shop_download_selling_point_desc3:"Explore e compre em um s\xf3 lugar, sem precisar sair da plataforma",tts_shop_download_selling_point_desc4:"\xd3timo custo-benef\xedcio em produtos em alta e exclusivos que voc\xea vai amar",tts_shop_download_selling_point_desc5:"Vendedores verificados, pagamentos seguros e prote\xe7\xf5es robustas garantem que cada transa\xe7\xe3o seja livre de preocupa\xe7\xf5es",tts_shop_download_selling_point_desc6:"Servi\xe7os como pagamentos confi\xe1veis, devolu\xe7\xf5es gratuitas e frete gr\xe1tis tornam sua experi\xeancia de compra descomplicada",tts_shop_download_selling_point_title1:"Recomenda\xe7\xf5es de pessoas como voc\xea",tts_shop_download_selling_point_title2:"Conte\xfado inspirador de transmiss\xf5es ao vivo com produtos \xe0 venda",tts_shop_download_selling_point_title3:"Compre sem complica\xe7\xe3o, tudo no TikTok",tts_shop_download_selling_point_title4:"Produtos de qualidade por menos",tts_shop_download_selling_point_title5:"Compre com seguran\xe7a e confian\xe7a",tts_shop_download_selling_point_title6:"Servi\xe7o que n\xe3o acaba na venda",tts_shop_download_title2_h1:"Descubra, explore, compre. Tudo em um s\xf3 lugar!",tts_shop_download_title2_h2:"Aqui, um mundo de descobertas encontra a alegria de fazer compras. Tudo no TikTok. Cada deslizada na tela traz a chance de descobrir algo novo, \xfanico e inesperado, inspirado pela comunidade que voc\xea ama.",tts_shop_download_title3_h1:"Uma experi\xeancia de compra feita para voc\xea",tts_shop_download_title3_h2:"Atrav\xe9s de um conjunto perfeito de recursos de compra no aplicativo, o TikTok Shop capacita marcas e criadores para exibir e vender produtos diretamente no TikTok, o que transforma descobertas em compras",tts_shop_purchase_protections_in_depth_Delivery_guarantee:"Garantia de entrega",tts_shop_purchase_protections_in_depth_Delivery_guarantee_content:"Receba o reembolso autom\xe1tico se seu pacote for declarado como perdido ou danificado pela transportadora.",tts_shop_purchase_protections_in_depth_Easy_returns_and_refunds:"Devolu\xe7\xf5es e reembolsos f\xe1ceis",tts_shop_purchase_protections_in_depth_Easy_returns_and_refunds_content1:"Devolu\xe7\xf5es gratuitas na maioria dos itens por 30 dias",tts_shop_purchase_protections_in_depth_Easy_returns_and_refunds_content2:"Entregas f\xe1ceis na UPS, USPS, FedEx ou Walgreens",tts_shop_purchase_protections_in_depth_Easy_returns_and_refunds_content3:"Nenhuma caixa/etiqueta necess\xe1ria na UPS; basta ler o c\xf3digo QR",tts_shop_purchase_protections_in_depth_Easy_returns_and_refunds_content4:"Reembolsos instant\xe2neos na entrega para devolu\xe7\xf5es qualificadas",tts_shop_purchase_protections_in_depth_Secure_Payments_content1:"O TikTok Shop utiliza m\xe9todos de pagamento altamente seguros. As transa\xe7\xf5es s\xe3o totalmente criptografadas e regulamentadas pelo Padr\xe3o de seguran\xe7a de dados do setor de cart\xf5es de pagamento (PCI DSS).",tts_shop_purchase_protections_in_depth_Secure_Payments_content2:"Nunca compartilhamos informa\xe7\xf5es de pagamento com os vendedores.",tts_shop_purchase_protections_in_depth_Secure_Payments_content3:"Aceitamos as seguintes formas de pagamento:",tts_shop_purchase_protections_in_depth_Secure_Payments_content4:"Certifica\xe7\xf5es de seguran\xe7a:",tts_shop_purchase_protections_in_depth_data_privacy_content1:"Estamos comprometidos em respeitar a sua privacidade. V\xe1rias salvaguardas protegem seus dados, e nunca compartilharemos ou venderemos suas informa\xe7\xf5es sem o seu consentimento.",tts_shop_purchase_protections_in_depth_data_privacy_content2:"Acesse a pol\xedtica de privacidade do TikTok Shop para entender seus direitos, m\xe9todos de seguran\xe7a de dados e uso de qualquer informa\xe7\xe3o.",tts_shop_purchase_protections_in_depth_data_privacy_content3:"Precisa de ajuda? Nossa central de ajuda virtual est\xe1 dispon\xedvel no aplicativo do TikTok todos os dias, 24 horas por dia, e nossos agentes em tempo real est\xe3o prontos para ajudar voc\xea durante o hor\xe1rio comercial.",tts_shop_purchase_protections_in_depth_learn_more:"Saiba mais",tts_shop_purchase_protections_in_depth_money_back_guarantee_content:"Nossa cobertura \xe9 gr\xe1tis e autom\xe1tica em pedidos eleg\xedveis por at\xe9 90 dias, caso seu item chegue danificado ou com defeitos. Limita\xe7\xf5es e exce\xe7\xf5es se aplicam.",tts_shop_purchase_protections_in_depth_secure_payments_content5:"Para usar quaisquer das op\xe7\xf5es de pagamento abaixo, conclua sua compra no aplicativo:",tts_shop_purchase_protections_in_depth_subtitle:"Temos o compromisso de proporcionar a voc\xea uma \xf3tima experi\xeancia de compra.",tts_shop_purchase_protections_module_subtitle1:"Pagamentos seguros",tts_shop_purchase_protections_module_subtitle2:"Garantia de reembolso",tts_shop_purchase_protections_module_subtitle4:"Suporte 24 horas por dia no aplicativo",tts_shop_purchase_protections_module_subtitle5:"Privacidade de dados",tts_shop_purchase_protections_module_title:"Prote\xe7\xf5es do TikTok Shop",tts_shop_web_promotion_tiktok_picks:"Escolhas do TikTok",tts_web_seo_coupon_center_title:"Coupon center",ug_paid_ads_seo_Shop_BR:"TikTok Shop Brazil",ug_paid_ads_seo_Shop_MX:"TikTok Shop M\xe9xico",ug_paid_ads_seo_Shop_Tokopedia:"Shop | Tokopedia",ug_paid_ads_seo_TikTok_Shop_Malaysia:"TikTok Shop Malaysia",ug_paid_ads_seo_TikTok_Shop_Philippines:"TikTok Shop Philippines",ug_paid_ads_seo_TikTok_Shop_Singapore:"TikTok Shop Singapore",ug_paid_ads_seo_TikTok_Shop_Thailand:"TikTok Shop Thailand",ug_paid_ads_seo_TikTok_Shop_UK:"TikTok Shop UK",ug_paid_ads_seo_TikTok_Shop_US:"TikTok Shop",ug_paid_ads_seo_TikTok_Shop_Vietnam:"TikTok Shop Vietnam",ug_paid_ads_seo_cat_reviews:"Avalia\xe7\xf5es em destaque",ug_paid_ads_seo_footer_affiliate:"Afiliado",ug_paid_ads_seo_footer_buy:"Comprar",ug_paid_ads_seo_footer_buy_promo_code:"C\xf3digos promocionais",ug_paid_ads_seo_footer_buy_website:"Sites globais do TikTok Shop",ug_paid_ads_seo_footer_careers:"Carreiras",ug_paid_ads_seo_footer_community_guidelines:"Diretrizes da comunidade",ug_paid_ads_seo_footer_company_info:"Sobre",ug_paid_ads_seo_footer_contact_us:"Fale conosco",ug_paid_ads_seo_footer_customer_service:"Suporte ao cliente",ug_paid_ads_seo_footer_make_money_with_us:"Vender",ug_paid_ads_seo_footer_policy_legal:"Jur\xeddico",ug_paid_ads_seo_footer_privacy_policy:"Pol\xedtica de privacidade",ug_paid_ads_seo_footer_seller_center:"Central do vendedor",ug_paid_ads_seo_footer_terms_of_service:"Termos de Servi\xe7o",ug_paid_ads_seo_friendly_category_page_description_new:"Descubra o mais recente {cate_name} no {TikTok_shop_country} e receba frete gr\xe1tis para itens qualificados. Explore cole\xe7\xf5es exclusivas e compre agora!",ug_paid_ads_seo_friendly_category_page_tittle_new:"{cate_name} - {TikTok_shop_country}",ug_paid_ads_seo_history_views:"Suas visualiza\xe7\xf5es",ug_paid_ads_seo_homepage_categories:"Categorias",ug_paid_ads_seo_homepage_description:"Discover deals on clothing, beauty, electronics & more at TikTok Shop. Enjoy free shipping on orders. Join now for exclusive offers!",ug_paid_ads_seo_homepage_description__new:"Descubra ofertas em roupas, beleza, eletr\xf4nicos e muito mais no {TikTok_shop_country}. Receba frete gr\xe1tis em itens eleg\xedveis. Compre agora para desbloquear ofertas exclusivas!",ug_paid_ads_seo_homepage_keywords:"TikTok Shop",ug_paid_ads_seo_homepage_title:"TikTok Shop: Free Shipping on Clothing, Beauty & More",ug_paid_ads_seo_homepage_title_new:"{TikTok_shop_country}: Frete gr\xe1tis para roupas, produtos de beleza e muito mais",ug_paid_ads_seo_homepage_top_selling:"Mais vendidos",ug_paid_ads_seo_login_create_account:"Criar conta",ug_paid_ads_seo_login_hi_there:"Boas-vindas! Pronto para economizar?",ug_paid_ads_seo_login_main_title:"Fa\xe7a login para ver seus descontos exclusivos.",ug_paid_ads_seo_pc_feedback:"Feedback e ajuda",ug_paid_ads_seo_pc_get_app:"Obter o aplicativo","ug_paid_ads_seo_pc_global reviews":"{review_count_str} avalia\xe7\xf5es globais",ug_paid_ads_seo_pc_load_more:"Ver mais",ug_paid_ads_seo_pc_sell:"Vender",ug_paid_ads_seo_pc_settings:"Configura\xe7\xf5es",ug_paid_ads_seo_review_all_photos:"Todas as fotos",ug_paid_ads_seo_review_medias_from_reviews:"Fotos de avalia\xe7\xf5es",ug_paid_ads_seo_review_see_all_photos:"Ver todas as fotos",ug_paid_ads_seo_shopguide:"Popular agora",ug_paid_ads_seo_shopguide_tag1:"Oferta",ug_paid_ads_seo_sitemap_description:"Descubra uma ampla gama de categorias no {TikTok_shop_country} e encontre todos os itens essenciais em um s\xf3 lugar! Compre moda, eletr\xf4nicos e muito mais com ofertas exclusivas e frete gr\xe1tis em itens selecionados.",ug_paid_ads_seo_sitemap_tab:"Comprar todas as categorias",ug_paid_ads_seo_sitemap_title:"Compre todas as categorias no {TikTok_shop_country} | Frete gr\xe1tis e ofertas incr\xedveis",web2app_landingpage_count_down_da_plural:"dias"}},de:{},"de-DE":{},fr:{},"fr-FR":{},it:{},"it-IT":{}}},disableDefaultRequest:!0,disableLanguageDetect:!0},(l||{}).intl,((l||{}).intlByEntries||{}).main,((0,b.nB)()||{}).intl))),sc.push((m=M({serverBase:["/"]},(l||{}).router,((l||{}).routerByEntries||{}).main,((0,b.nB)()||{}).router),(0,P._)((0,C._)({},function(){var e=arguments.length>0&&void 0!==arguments[0]?arguments[0]:{};return{name:"@modern-js/plugin-router",registryHooks:{modifyRoutes:iJ,onBeforeCreateRoutes:iX},setup:function(t){var n={current:[]};t.onBeforeRender(function(t){if(window._SSR_DATA&&e.unstable_reloadOnURLMismatch){var r,o=t.ssrContext,a=iZ(window.location.pathname),i=(null==o||null==(r=o.request)?void 0:r.pathname)&&iZ(o.request.pathname);i&&i!==a&&(cons