TikTok_shop_country}",ug_paid_ads_seo_history_views:"Tayangan Anda",ug_paid_ads_seo_homepage_categories:"Kategori",ug_paid_ads_seo_homepage_description:"Temukan promo untuk produk pakaian, kecantikan, elektronik, & banyak lagi di TikTok Shop. Nikmati pengiriman gratis untuk pesanan Anda dan gabung sekarang juga untuk mendapatkan promo eksklusif!",ug_paid_ads_seo_homepage_description__new:"Temukan promo untuk produk pakaian, kecantikan, elektronik, & banyak lagi di {TikTok_shop_country}. Dapatkan gratis ongkir untuk produk yang memenuhi syarat. Belanja sekarang dan dapatkan promo eksklusif!",ug_paid_ads_seo_homepage_keywords:"TikTok Shop",ug_paid_ads_seo_homepage_title:"TikTok Shop: Pengiriman Gratis untuk Produk Pakaian, Kecantikan, & Banyak Lagi",ug_paid_ads_seo_homepage_title_new:"{TikTok_shop_country}: Gratis Ongkir untuk Produk Pakaian, Kecantikan, & Banyak Lagi",ug_paid_ads_seo_homepage_top_selling:"Terlaris",ug_paid_ads_seo_login_create_account:"Buat Akun",ug_paid_ads_seo_login_hi_there:"Selamat datang! Siap Banjir Diskon?",ug_paid_ads_seo_login_main_title:"Login untuk melihat diskon eksklusif Anda.",ug_paid_ads_seo_pc_feedback:"Masukan dan bantuan",ug_paid_ads_seo_pc_get_app:"Dapatkan aplikasi","ug_paid_ads_seo_pc_global reviews":"{review_count_str} ulasan global",ug_paid_ads_seo_pc_load_more:"Tampilkan lainnya",ug_paid_ads_seo_pc_sell:"Jual",ug_paid_ads_seo_pc_settings:"Pengaturan",ug_paid_ads_seo_review_all_photos:"Semua foto",ug_paid_ads_seo_review_medias_from_reviews:"Foto dari pengulas",ug_paid_ads_seo_review_see_all_photos:"Lihat semua foto",ug_paid_ads_seo_shopguide:"Trending sekarang",ug_paid_ads_seo_shopguide_tag1:"Promo",ug_paid_ads_seo_sitemap_description:"Temukan aneka kategori produk di {TikTok_shop_country} dan semua kebutuhan Anda di satu tempat! Belanja produk dari kategori fashion, elektronik, dan banyak lagi dengan promo eksklusif serta gratis ongkir untuk produk tertentu.",ug_paid_ads_seo_sitemap_tab:"Belanja Semua Kategori",ug_paid_ads_seo